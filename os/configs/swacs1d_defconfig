BR2_x86_64=y
BR2_TOOLCHAIN_BUILDROOT_MUSL=y
BR2_TOOLCHAIN_BUILDROOT_CXX=y
BR2_PACKAGE_HOST_RUSTC=y

# System Core & X11
BR2_INIT_BUSYBOX=y
BR2_ROOTFS_DEVICE_CREATION_DYNAMIC_EUDEV=y
BR2_SYSTEM_DHCP="eth0"
BR2_PACKAGE_XSERVER_XORG_SERVER=y
BR2_PACKAGE_XSERVER_XORG_SERVER_MODULAR=y

# Graphics (Intel, AMD, Nvidia)
BR2_PACKAGE_MESA3D=y
BR2_PACKAGE_MESA3D_GALLIUM_DRIVER_IRIS=y
BR2_PACKAGE_MESA3D_GALLIUM_DRIVER_RADEONSI=y
BR2_PACKAGE_MESA3D_GALLIUM_DRIVER_NOUVEAU=y
BR2_PACKAGE_MESA3D_OPENGL_EGL=y
BR2_PACKAGE_MESA3D_OPENGL_ES=y
BR2_PACKAGE_MESA3D_GBM=y

# SDL3 & Media (LGPL)
BR2_PACKAGE_SDL3=y
BR2_PACKAGE_SDL3_X11=y
BR2_PACKAGE_SDL3_KMSDRM=y
BR2_PACKAGE_SDL3_IMAGE=y
BR2_PACKAGE_SDL3_TTF=y
BR2_PACKAGE_SDL3_MIXER=y
BR2_PACKAGE_FFMPEG=y
BR2_PACKAGE_FFMPEG_SWSCALE=y
BR2_PACKAGE_LIBVA=y
BR2_PACKAGE_INTEL_MEDIA_DRIVER=y
BR2_PACKAGE_ALSA_LIB=y
BR2_PACKAGE_OPUSFILE=y
BR2_PACKAGE_LIBVORBIS=y
BR2_PACKAGE_FLAC=y

# Disk & Security
BR2_PACKAGE_GPTFDISK=y
BR2_PACKAGE_E2FSPROGS=y
BR2_PACKAGE_CRYPTSETUP=y
BR2_PACKAGE_TPM2_TOOLS=y
BR2_PACKAGE_OPENSSL=y
BR2_PACKAGE_JQ=y
BR2_PACKAGE_ZSTD=y

# Filesystem
BR2_TARGET_ROOTFS_SQUASHFS=y
BR2_PACKAGE_HOST_GENIMAGE=y
BR2_ROOTFS_POST_IMAGE_SCRIPT="support/scripts/genimage.sh"
BR2_ROOTFS_POST_SCRIPT_ARGS="-c board/swacs1d/genimage.cfg"
BR2_ROOTFS_OVERLAY="board/swacs1d/rootfs_overlay"