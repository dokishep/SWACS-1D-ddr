#!/bin/sh

SECURE_BOOT=0

# Check if booted via EFI
if [ -d /sys/firmware/efi ]; then
    # Mount efivarfs if not already mounted
    if [ ! -d /sys/firmware/efi/efivars ]; then
        mount -t efivarfs efivarfs /sys/firmware/efi/efivars -o nosuid,nodev,noexec 2>/dev/null
    elif ! mount | grep -q "sys/firmware/efi/efivars"; then
        mount -t efivarfs efivarfs /sys/firmware/efi/efivars -o nosuid,nodev,noexec 2>/dev/null
    fi

    # Read SecureBoot variable
    SB_FILE="/sys/firmware/efi/efivars/SecureBoot-8be4df61-93ca-11d2-aa0d-00e098032b8c"
    if [ -f "$SB_FILE" ]; then
        # The 5th byte (offset 4) contains the value: 1 for enabled, 0 for disabled
        SB_VAL=$(od -An -t u1 -j 4 "$SB_FILE" 2>/dev/null | tr -d ' \n\t')
        if [ "$SB_VAL" = "1" ]; then
            SECURE_BOOT=1
        fi
    fi
fi

if [ "$SECURE_BOOT" = "0" ]; then
    # Print exact required warning block to physical console
    cat << 'EOF' > /dev/tty1

ERROR!
Secure Boot is disabled, which is essential to guarantee the operating system integrity!
Without Secure Boot, the board is vulnerable to boot-level malware and tampering.
Check the board UEFI settings and enable Secure Boot. If this setting is disabled, the system will not boot!
Press Enter to shut down...
EOF

    # Start graphical warning screen in Xorg
    /usr/bin/xinit /usr/bin/start_secureboot_error.sh -- /usr/bin/Xorg :0 vt7 -nocursor -quiet -s 0 -dpms &
    XINIT_PID=$!

    # Wait for Enter on tty1 OR for the X11 screen to close
    ( read -r < /dev/tty1; kill $XINIT_PID 2>/dev/null ) &
    BG_READ_PID=$!

    # Block and wait
    wait $XINIT_PID 2>/dev/null
    kill $BG_READ_PID 2>/dev/null

    # Shut down immediately
    poweroff -f
fi
