#!/bin/sh

# Detect and configure TPM device TCTI
TPM_WORKING=0

if [ -c /dev/tpmrm0 ]; then
    export TPM2TOOLS_TCTI="device:/dev/tpmrm0"
    TPM_WORKING=1
elif [ -c /dev/tpm0 ]; then
    export TPM2TOOLS_TCTI="device:/dev/tpm0"
    TPM_WORKING=1
fi

if [ "$TPM_WORKING" = "1" ]; then
    if tpm2_getcap properties-fixed >/dev/null 2>&1; then
        TPM_WORKING=1
    else
        TPM_WORKING=0
    fi
fi

if [ "$TPM_WORKING" = "0" ]; then
    # Print exact required warning block to physical console
    cat << 'EOF' > /dev/tty1

ERROR!
This board doesn't support TPM, which is essential to guarantee game data integrity!
Without TPM, the board isn't eligible to be factory provisioned, and any attempts of doing so will be blocked to prevent data tampering.
Check the board UEFI settings for Security/TPM settings and enable TPM 2.0, if this setting is disabled later, the board will not boot!
Press Enter to shut down...
EOF

    # Start graphical warning screen in Xorg
    /usr/bin/xinit /usr/bin/start_tpm_error.sh -- /usr/bin/Xorg :0 vt7 -nocursor -quiet -s 0 -dpms &
    XINIT_PID=$!

    # Wait for Enter on tty1 OR for the X11 screen to close
    ( read -r < /dev/tty1; kill $XINIT_PID 2>/dev/null ) &
    BG_READ_PID=$!

    # Block and wait
    wait $XINIT_PID 2>/dev/null
    kill $BG_READ_PID 2>/dev/null

    # Shut down immediately
    poweroff -f
fi
