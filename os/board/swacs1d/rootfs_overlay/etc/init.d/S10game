#!/bin/sh
GAME_DEV="/dev/disk/by-partlabel/GAME"
SCORE_DEV="/dev/disk/by-partlabel/SCORE"

# Mount Score Partition for highscores
if [ -b "$SCORE_DEV" ]; then
    mount -o rw,noatime "$SCORE_DEV" /var/data
    
    # Generate 8-digit cabinet ID if not already present
    EXISTING_ID_FILE=$(find /var/data -maxdepth 1 -name "[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9].txt" | head -n 1)
    if [ -z "$EXISTING_ID_FILE" ]; then
        CABINET_ID=$(printf "%08d" $(( $(od -An -N4 -tu4 /dev/urandom) % 100000000 )))
        echo "$CABINET_ID" > "/var/data/${CABINET_ID}.txt"
        echo "Generated cabinet ID: $CABINET_ID"
    else
        CABINET_ID=$(basename "$EXISTING_ID_FILE" .txt)
        echo "Found existing cabinet ID: $CABINET_ID"
    fi
fi

# Unlock Game Partition via TPM
if cryptsetup isLuks "$GAME_DEV"; then
    if [ -c /dev/tpmrm0 ]; then
        export TPM2TOOLS_TCTI="device:/dev/tpmrm0"
    elif [ -c /dev/tpm0 ]; then
        export TPM2TOOLS_TCTI="device:/dev/tpm0"
    fi

    tpm2_unseal -c 0x81010002 | cryptsetup luksOpen "$GAME_DEV" game_crypt -d -
    mount -o ro,nosuid,nodev /dev/mapper/game_crypt /opt/game
fi