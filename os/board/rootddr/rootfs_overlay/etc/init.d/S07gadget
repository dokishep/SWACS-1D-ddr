#!/bin/sh
# S07gadget — USB Gadget Initialization for PS1 Memory Card Emulation
# Runs at init priority S07 to set up the USB OTG gadget using the memory card
# selected by S10memory_card.sh (runs earlier in the boot sequence).
#
# Boot order:
#   S06usbports   → USB port mapping daemon + hot-plug monitor
#   S10memory_card.sh → game detection + memory card selection
#   S07gadget    ← (this script) reads active card and initialises the gadget

ACTIVE_CARD="/var/data/memcard.bin"
GADGET_INIT="/usr/local/bin/gadget-init.sh"

case "$1" in
    start)
        # S10memory_card.sh runs at S10 (before S07) — read its result.
        # If it did not set an active card symlink, fall back to the default.
        if [ ! -f "$ACTIVE_CARD" ] && [ ! -L "$ACTIVE_CARD" ]; then
            echo "Warning: no active memory card from S10memory_card.sh, creating default..."
            if [ -x /etc/init.d/S10memory_card.sh ]; then
                /etc/init.d/S10memory_card.sh start
            fi
        fi

        # Pass the resolved active card to gadget-init.sh via -f flag
        _card_args=""
        if [ -f "$ACTIVE_CARD" ] || [ -L "$ACTIVE_CARD" ]; then
            _resolved_readlink=$(readlink -f "$ACTIVE_CARD" 2>/dev/null || readlink "$ACTIVE_CARD")
            if [ -n "$_resolved_readlink" ]; then
                _card_args="-f $_resolved_readlink"
                echo "Active memory card: $(basename "$_resolved_readlink")"
            fi
        fi

        if [ -x "$GADGET_INIT" ]; then
            echo "Initialising USB gadget with game-specific memory card..."
            eval "$GADGET_INIT $_card_args"
        else
            echo "Error: $GADGET_INIT not found or not executable" >&2
            exit 1
        fi
        ;;

    stop)
        # Unbind gadget — clean up current and any player-suffixed variants
        _stop_gadget() {
            local gad="$1"
            if [ -d "/sys/kernel/config/usb_gadget/${gad}" ]; then
                echo "" > "/sys/kernel/config/usb_gadget/${gad}/UDC" 2>/dev/null || true
                echo "Stopped gadget: ${gad}"
            fi
        }
        _stop_gadget "ps1-memcard"
        _stop_gadget "ps1-memcard.p1"
        _stop_gadget "ps1-memcard.p2"
        ;;

    restart)
        $0 stop
        $0 start
        ;;

    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0